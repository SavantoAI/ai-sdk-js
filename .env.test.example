# Integration test configuration
# Copy to .env.test and fill in values

# Required: a secret API key with full access
SAVANTO_API_KEY=if_sk_...

# API endpoint (default: http://localhost:3001)
SAVANTO_API_ENDPOINT=http://localhost:3001

# Streaming endpoint (default: same as API endpoint)
SAVANTO_STREAMING_ENDPOINT=http://localhost:3001

# Workspace ID to test against
SAVANTO_WORKSPACE_ID=
